{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm -r --parallel typecheck)",
      "Bash(pnpm -r --parallel test)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm lint)",
      "Bash(pnpm --filter @rcao-quiz/sdk test)",
      "Bash(pnpm --filter @rcao-quiz/sdk typecheck)",
      "Bash(pnpm --filter @rcao-quiz/mobile typecheck)",
      "Bash(pnpm --filter @rcao-quiz/mobile test)",
      "Bash(xcrun simctl list *)",
      "Bash(xcrun simctl listapps *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'git\\s+commit'; then bash .claude/hooks/pre-commit-typecheck.sh && bash .claude/hooks/pre-commit-secrets.sh; fi"
          }
        ]
      }
    ]
  }
}
