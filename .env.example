# Postgres
DATABASE_URL=postgres://rcao:rcao@localhost:5432/rcao_quiz

# API
API_PORT=4000
WEB_URL=http://localhost:3000

# JWT (generate locally: openssl rand -hex 32)
JWT_SECRET=replace-me

# Pack output (Phase 0: local disk; served by web dev server)
PACKS_DIR=./packs

# Cloudflare R2 (Phase 1+; leave blank in Phase 0)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=rcao-quiz-packs
# R2_PUBLIC_BASE_URL=https://packs.rcao-quiz.example
