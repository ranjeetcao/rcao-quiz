# Phase 0 — local dev only
# Copy to `.env` and adjust for your machine.

# Where the Expo app fetches packs from. In Phase 0, `pnpm packs:serve` serves
# ./packs/ over plain HTTP.
#   - iOS Simulator:    http://localhost:8787
#   - Android Emulator: http://10.0.2.2:8787 (loopback to host)
#   - Physical device:  http://<your-LAN-IP>:8787 (e.g. 192.168.1.42)
EXPO_PUBLIC_PACKS_BASE_URL=http://localhost:8787

# Phase 1+ — set when those phases land.
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=rcao-quiz-packs
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://packs.rcao-quiz.example
# ANTHROPIC_API_KEY=
# SLACK_WEBHOOK_URL=
